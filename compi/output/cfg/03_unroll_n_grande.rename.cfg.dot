digraph "03_unroll_n_grande.rename" {
  rankdir=TB;
  graph [fontname="Helvetica", labelloc="t"];
  node [shape=box, fontname="Courier", style="rounded"];
  edge [fontname="Helvetica"];

  "B_label_main" [label="B_label_main\lmain:\li = 0\lsuma = 0\l"];
  "B_label_L_while_start_0" [label="B_label_L_while_start_0\lL_while_start_0:\lt0__x3 = i < 32\lifFalse t0__x3 goto L_while_end_1\l"];
  "B_fallthrough_2" [label="B_fallthrough_2\lt1__x4 = suma + i\lsuma = t1__x4\lt2__x5 = i + 1\li = t2__x5\lgoto L_while_start_0\l"];
  "B_label_L_while_end_1" [label="B_label_L_while_end_1\lL_while_end_1:\lreturn suma\l"];

  "B_label_main" -> "B_label_L_while_start_0" [label="fallthrough", color="#555555"];
  "B_label_L_while_start_0" -> "B_label_L_while_end_1" [label="false", color="#B22222"];
  "B_label_L_while_start_0" -> "B_fallthrough_2" [label="true", color="#2E8B57"];
  "B_fallthrough_2" -> "B_label_L_while_start_0" [label="jump", color="#4169E1"];
}
