digraph "bench_seq.unroll" {
  rankdir=TB;
  graph [fontname="Helvetica", labelloc="t"];
  node [shape=box, fontname="Courier", style="rounded"];
  edge [fontname="Helvetica"];

  "B_label_main" [label="B_label_main\lmain:\larr = 0\li = 0\lsuma = 0\l"];
  "B_label_L_while_start_0" [label="B_label_L_while_start_0\lL_while_start_0:\lt6 = i < 256\lifFalse t6 goto L_while_end_1\l"];
  "B_fallthrough_2" [label="B_fallthrough_2\larr[i] = i\larr[(i + 1)] = (i + 1)\larr[(i + 2)] = (i + 2)\larr[(i + 3)] = (i + 3)\larr[(i + 4)] = (i + 4)\larr[(i + 5)] = (i + 5)\larr[(i + 6)] = (i + 6)\larr[(i + 7)] = (i + 7)\lt7 = i + 8\li = t7\lgoto L_while_start_0\l"];
  "B_label_L_while_end_1" [label="B_label_L_while_end_1\lL_while_end_1:\li = 0\l"];
  "B_label_L_while_start_2" [label="B_label_L_while_start_2\lL_while_start_2:\lt8 = i < 256\lifFalse t8 goto L_while_end_3\l"];
  "B_fallthrough_5" [label="B_fallthrough_5\lt9 = arr[i]\lt10 = suma + t9\lsuma = t10\lt11 = arr[(i + 1)]\lt12 = suma + t11\lsuma = t12\lt13 = arr[(i + 2)]\lt14 = suma + t13\lsuma = t14\lt15 = arr[(i + 3)]\lt16 = suma + t15\lsuma = t16\lt17 = i + 4\li = t17\lgoto L_while_start_2\l"];
  "B_label_L_while_end_3" [label="B_label_L_while_end_3\lL_while_end_3:\lreturn suma\l"];

  "B_label_main" -> "B_label_L_while_start_0" [label="fallthrough", color="#555555"];
  "B_label_L_while_start_0" -> "B_label_L_while_end_1" [label="false", color="#B22222"];
  "B_label_L_while_start_0" -> "B_fallthrough_2" [label="true", color="#2E8B57"];
  "B_fallthrough_2" -> "B_label_L_while_start_0" [label="jump", color="#4169E1"];
  "B_label_L_while_end_1" -> "B_label_L_while_start_2" [label="fallthrough", color="#555555"];
  "B_label_L_while_start_2" -> "B_label_L_while_end_3" [label="false", color="#B22222"];
  "B_label_L_while_start_2" -> "B_fallthrough_5" [label="true", color="#2E8B57"];
  "B_fallthrough_5" -> "B_label_L_while_start_2" [label="jump", color="#4169E1"];
}
