digraph "11_reorder_load_branch_funcion" {
  rankdir=TB;
  graph [fontname="Helvetica", labelloc="t"];
  node [shape=box, fontname="Courier", style="rounded"];
  edge [fontname="Helvetica"];

  "B_label_seleccionar" [label="B_label_seleccionar\lseleccionar:\lt0 = valor < respaldo\lifFalse t0 goto L_else_0\l"];
  "B_fallthrough_1" [label="B_fallthrough_1\lreturn respaldo\l"];
  "B_fallthrough_2" [label="B_fallthrough_2\lgoto L_end_if_1\l"];
  "B_label_L_else_0" [label="B_label_L_else_0\lL_else_0:\l"];
  "B_label_L_end_if_1" [label="B_label_L_end_if_1\lL_end_if_1:\lreturn valor\l"];
  "B_label_main" [label="B_label_main\lmain:\ldatos = [8, 21, 13]\lt1 = datos[1]\lcargado = t1\lt2 = 5 + 6\lindependiente = t2\lt3 = cargado + 1\lcandidato = t3\lt4 = call seleccionar(candidato, independiente)\lelegido = t4\lt5 = elegido == 22\lifFalse t5 goto L_else_2\l"];
  "B_fallthrough_6" [label="B_fallthrough_6\lt6 = elegido + independiente\lreturn t6\l"];
  "B_fallthrough_7" [label="B_fallthrough_7\lgoto L_end_if_3\l"];
  "B_label_L_else_2" [label="B_label_L_else_2\lL_else_2:\l"];
  "B_label_L_end_if_3" [label="B_label_L_end_if_3\lL_end_if_3:\lreturn 0\l"];

  "B_label_seleccionar" -> "B_label_L_else_0" [label="false", color="#B22222"];
  "B_label_seleccionar" -> "B_fallthrough_1" [label="true", color="#2E8B57"];
  "B_fallthrough_2" -> "B_label_L_end_if_1" [label="jump", color="#4169E1"];
  "B_label_L_else_0" -> "B_label_L_end_if_1" [label="fallthrough", color="#555555"];
  "B_label_main" -> "B_label_L_else_2" [label="false", color="#B22222"];
  "B_label_main" -> "B_fallthrough_6" [label="true", color="#2E8B57"];
  "B_fallthrough_7" -> "B_label_L_end_if_3" [label="jump", color="#4169E1"];
  "B_label_L_else_2" -> "B_label_L_end_if_3" [label="fallthrough", color="#555555"];
}
