digraph "08_dce_dos_llamadas_con_efecto" {
  rankdir=TB;
  graph [fontname="Helvetica", labelloc="t"];
  node [shape=box, fontname="Courier", style="rounded"];
  edge [fontname="Helvetica"];

  "B_entry" [label="B_entry\lacumulado = 1\l"];
  "B_label_acumular" [label="B_label_acumular\lacumular:\lt0 = acumulado + valor\lacumulado = t0\lreturn acumulado\l"];
  "B_label_main" [label="B_label_main\lmain:\lsemilla = 10\lt1 = semilla * 8\lcadena_muerta = t1\lt2 = cadena_muerta + 77\lcadena_muerta = t2\lt3 = call acumular(2)\lt4 = cadena_muerta * 3\lotro_muerto = t4\lt5 = call acumular(4)\lt6 = otro_muerto + 1\lotro_muerto = t6\lreturn acumulado\l"];

  "B_entry" -> "B_label_acumular" [label="fallthrough", color="#555555"];
}
