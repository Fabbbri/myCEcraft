digraph "demo.O3" {
  rankdir=TB;
  graph [fontname="Helvetica", labelloc="t"];
  node [shape=box, fontname="Courier", style="rounded"];
  edge [fontname="Helvetica"];

  "B_label_main" [label="B_label_main\lmain:\lx = 0\l"];
  "B_label_L_while_start_0" [label="B_label_L_while_start_0\lL_while_start_0:\lt2__x3 = x < 4\lifFalse t2__x3 goto L_while_end_1\l"];
  "B_fallthrough_2" [label="B_fallthrough_2\lt3__x4 = x + 2\lx = t3__x4\lgoto L_while_start_0\l"];
  "B_label_L_while_end_1" [label="B_label_L_while_end_1\lL_while_end_1:\lt4__x5 = x + 1\lx = t4__x5\lreturn x\l"];

  "B_label_main" -> "B_label_L_while_start_0" [label="fallthrough", color="#555555"];
  "B_label_L_while_start_0" -> "B_label_L_while_end_1" [label="false", color="#B22222"];
  "B_label_L_while_start_0" -> "B_fallthrough_2" [label="true", color="#2E8B57"];
  "B_fallthrough_2" -> "B_label_L_while_start_0" [label="jump", color="#4169E1"];
}
