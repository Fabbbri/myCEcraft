digraph "01_unroll_for_limite_literal.dce" {
  rankdir=TB;
  graph [fontname="Helvetica", labelloc="t"];
  node [shape=box, fontname="Courier", style="rounded"];
  edge [fontname="Helvetica"];

  "B_label_main" [label="B_label_main\lmain:\lsuma_a = 0\lsuma_b = 0\li = 0\l"];
  "B_label_L_for_start_0" [label="B_label_L_for_start_0\lL_for_start_0:\lt0 = i < 8\lifFalse t0 goto L_for_end_1\l"];
  "B_fallthrough_2" [label="B_fallthrough_2\lt1 = suma_a + i\lsuma_a = t1\lt2 = suma_b + i\lt3 = t2 + 1\lsuma_b = t3\lt4 = i + 2\li = t4\lgoto L_for_start_0\l"];
  "B_label_L_for_end_1" [label="B_label_L_for_end_1\lL_for_end_1:\lt5 = suma_a + suma_b\lreturn t5\l"];

  "B_label_main" -> "B_label_L_for_start_0" [label="fallthrough", color="#555555"];
  "B_label_L_for_start_0" -> "B_label_L_for_end_1" [label="false", color="#B22222"];
  "B_label_L_for_start_0" -> "B_fallthrough_2" [label="true", color="#2E8B57"];
  "B_fallthrough_2" -> "B_label_L_for_start_0" [label="jump", color="#4169E1"];
}
