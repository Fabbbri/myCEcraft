@EnterCraftWorld

craft:int factorial(n:int) {
    resultado:int = 1;
    i:int = 1;
    while (i <= n) {
        resultado = resultado * i;
        i = i + 1;
    }
    return resultado;
}

craft:int main() {
    a:int = 2;
    b:int = 3;
    r1:int = summon:factorial(a + b);
    r2:int = summon:factorial(a + 1);
    return r1 + r2;
}
