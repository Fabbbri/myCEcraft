@EnterCraftWorld
// --- import: /home/fabbbri/Escritorio/myCEcraft/compi/Defensa/P1/maximo_lista.craft ---

craft:int maximo_lista(lista:chest[int, 7], largo:int) {
    maximo:int = lista[0];
    num:int = 0;
    esMayor:int = 0;
    limite:int = largo;

    for (i:int = 0; i < limite + 0; i = i + 1) {
        num = lista[i];

        esMayor = num > maximo;

        if (esMayor + 0) {
            maximo = num;
        }
    }

    return maximo;
}
// --- fin import ---

craft:int main() {
    lista:chest[int, 7] = [3, 4, 5, 24, 5, 65, 46];
    return summon:maximo_lista(lista, 7);
}
