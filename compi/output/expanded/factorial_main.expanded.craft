@EnterCraftWorld
// --- import: C:\Users\snipe\Desktop\myCEcraft\compi\ejemplos\factorial.craft ---
craft:int factorial(n:int) {
    resultado:int = 1;
    i:int = 1;

    while (i <= n) {
        resultado = resultado * i;
        i = i + 1;
    }

    return resultado;
}
// --- fin import ---

craft:int main() {
    return summon:factorial(5);
}
