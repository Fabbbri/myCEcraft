@EnterCraftWorld
// --- import: /home/fabbbri/Escritorio/myCEcraft/compi/Defensa/maximo_lista.craft ---

craft:int maximo_lista(lista:chest[int, 7], largo:int) {
    maximo:int = lista[0];
    num:int = 0;
    esMayor:int = 0;
    limite:int = largo;

    for (i:int = 0; i < limite + 0; i = i + 1) {
        num = lista[i];

        esMayor = num > maximo;

        if (esMayor + 0) {
            maximo = num;
        }
    }

    return maximo;
}
// --- fin import ---

suma:int = 0;
multiplicacion:int = 1;
resultado:chest[int, 2] = [0, 0];

craft:int sumeMayores(lista:chest[int, 5], salida:chest[int, 2]) {
    valorMaximo:int = 0;
    seguir:int = 0;
    esDiez:int = 0;
    esGrande:int = 0;

    seguir = suma < 100;

    while (seguir + 0) {
        valorMaximo = summon:maximo_lista(lista, 5);

        esDiez = valorMaximo / 2 == 5;

        if (esDiez + 0) {
            valorMaximo = valorMaximo * 2;
        }

        suma = suma + valorMaximo;
        multiplicacion = multiplicacion * valorMaximo;

        esGrande = multiplicacion > 500;

        if (esGrande + 0) {
            multiplicacion = 10;
        } else {
            multiplicacion = multiplicacion - 10;
        }

        seguir = suma < 100;
    }

    salida[0] = suma;
    salida[1] = multiplicacion;

    return salida[0];
}

craft:int main() {
    lista:chest[int, 5] = [10, 2, 3, 4, 5];
    return summon:sumeMayores(lista, resultado);
}
