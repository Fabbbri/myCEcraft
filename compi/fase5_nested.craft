craft:int main() {
    x:int = 0;
    y:int = 0;

    while (x < 3) {
        if (y < 2) {
            y = y + 1;

            if (x == 1) {
                y = y + 2;
            } else {
                y = y + 3;
            }
        } else {
            y = y - 1;
        }

        x = x + 1;
    }

    return y;
}
