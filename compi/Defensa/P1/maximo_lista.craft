@EnterCraftWorld

craft:int maximo_lista(lista:chest[int, 7], largo:int) {
    maximo:int = lista[0];
    num:int = 0;
    esMayor:int = 0;
    limite:int = largo;

    for (i:int = 0; i < limite + 0; i = i + 1) {
        num = lista[i];

        esMayor = num > maximo;

        if (esMayor + 0) {
            maximo = num;
        }
    }

    return maximo;
}
