@EnterCraftWorld

// FOR con N constante grande (32). Factor auto = 8:
// 32 iteraciones -> 4 bloques de 8, overhead de salto dividido por 8.
// Dos acumuladores independientes para maximizar trabajo por iteracion.
// Resultado esperado: sum(0..31) = 496.
craft:int main() {
    par:int = 0;
    impar:int = 0;

    for (i:int = 0; i < 32; i = i + 2) {
        par = par + i;
        impar = impar + i + 1;
    }

    return par + impar;
}
