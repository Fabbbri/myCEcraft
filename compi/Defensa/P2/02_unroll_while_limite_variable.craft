@EnterCraftWorld

// N asignada como constante antes del loop: el unroller propaga su valor
// mediante constant folding y aplica unroll con factor 2, igual que si
// fuera un literal. Demuestra que el unroller va mas alla de literales
// directos en el codigo fuente.
// Resultado esperado: 0+1+2+3+4+5 = 15.
craft:int main() {
    n:int = 6;
    i:int = 0;
    suma:int = 0;

    while (i < n) {
        suma = suma + i;
        i = i + 1;
    }

    return suma;
}
