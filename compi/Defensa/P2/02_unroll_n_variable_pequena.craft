@EnterCraftWorld

// N es una variable en tiempo de ejecucion. El unroller conservador debe
// omitir este loop porque no puede demostrar estaticamente sus iteraciones.
// Resultado esperado: 0 + 1 + ... + 5 = 15.
craft:int main() {
    n:int = 6;
    i:int = 0;
    suma:int = 0;

    while (i < n) {
        suma = suma + i;
        i = i + 1;
    }

    return suma;
}
