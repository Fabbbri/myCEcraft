// DCE debe eliminar los calculos sin uso, pero conservar summon:marcar.
// Resultado esperado: 5.

estado:int = 0;

craft:int marcar(valor:int) {
    estado = estado + valor;
    return estado;
}

@EnterCraftWorld
craft:int main() {
    base:int = 4;
    muerto_antes:int = base * 99;

    summon:marcar(5);

    muerto_despues:int = muerto_antes + 123;
    return estado;
}
