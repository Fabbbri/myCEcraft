@EnterCraftWorld

// WAW: tres escrituras sobre a. Los resultados anteriores deben conservarse.
// Resultado esperado: 11 + 22 + 33 = 66.
craft:int main() {
    a:int = 1;
    primero:int = a + 10;

    a = 2;
    segundo:int = a + 20;

    a = 3;
    tercero:int = a + 30;

    return primero + segundo + tercero;
}
